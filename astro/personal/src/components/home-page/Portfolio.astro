---
import { Swiper, SwiperWrapper, SwiperSlide, } from 'astro-swiper';
import type { AstroSwiperOptions } from 'astro-swiper';
import classNames from 'classnames';
import ContentManager from '../ContentManager';
import { BCMSImage } from '@thebcms/components-react';
import './portfolio.css';
import type { PropRichTextDataParsed } from '@thebcms/types';
import type { ClientConfig } from '@thebcms/client';
import type { PortfolioEntryMetaItem } from '../../../bcms/types/ts';

interface Props {
    title: string;
    description: PropRichTextDataParsed;
    items: PortfolioEntryMetaItem[];
    bcmsConfig: ClientConfig;
}

const sliderOptions: AstroSwiperOptions = {
    slidesPerView: 1,
    watchOverflow: true,
    spaceBetween: 12,
};
const { title, description, items, bcmsConfig } = Astro.props;
---
<section class="pb-10 lg:pb-14">
    <div class="container">
        <div class="mb-8 md:flex md:items-start md:justify-between md:gap-16 lg:gap-20 lg:mb-10">
            <div class="flex items-center mb-[14px] md:mt-4">
                <div class="w-1.5 h-1.5 bg-appText rounded-full mr-2 lg:w-2.5 lg:h-2.5 lg:mr-4 lg:mt-1" />
                <h2 class="text-lg leading-none tracking-[-0.41px] font-Helvetica lg:text-[32px] lg:leading-none">
                    {title}
                </h2>
            </div>
            <div>
                <ContentManager
                    items={description.nodes}
                    className="text-sm leading-[1.4] tracking-[-0.41px] text-appGray-400 md:max-w-[761px] lg:text-base lg:leading-[1.4]"
                    client:load
                />
            </div>
        </div>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:gap-4 xl:grid-cols-[repeat(16,1fr)]">
            {items.map((item, index) => (
                <div
                    class={classNames(
                        'flex flex-col rounded-3xl p-6 lg:p-8 lg:pb-4',
                        index % 2 === 2 || index % 3 === 0
                            ? 'xl:col-span-7'
                            : 'xl:col-span-9',
                    )}
                    style={{ backgroundColor: item.theme }}
                >
                    <h3 class="leading-none tracking-[-0.41px] text-white mb-5 lg:text-xl lg:leading-none lg:mb-6">
                        {item.title}
                    </h3>
                    <a
                        href={`/portfolio/${item.slug}`}
                        class="group relative flex mb-auto w-full xl:flex-1"
                    >
                        <Swiper options={{
                                ...sliderOptions,
                                pagination: {
                                    el: `.homePortfolio--galleryPagination_${index}`,
                                }
                            }}
                            class="w-full rounded-3xl overflow-hidden"
                        >
                            <SwiperWrapper>
                                {item.gallery &&
                                    item.gallery.map(
                                        (galleryItem) => (
                                            <SwiperSlide
                                                class="w-full"
                                            >
                                                <BCMSImage
                                                    media={galleryItem}
                                                    clientConfig={
                                                        bcmsConfig
                                                    }
                                                    className={classNames(
                                                        'size-full aspect-[1.45] object-cover rounded-3xl overflow-hidden',
                                                        index % 2 === 2 ||
                                                            index % 3 === 0
                                                            ? 'xl:aspect-[1.45]'
                                                            : 'xl:aspect-[1.84]',
                                                    )}
                                                    client:load
                                                />
                                            </SwiperSlide>
                                        ),
                                    )}
                            </SwiperWrapper>
                        </Swiper>
                        <div
                            class="absolute z-10 top-0 left-0 w-full h-full rounded-3xl flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 group-hover:opacity-100"
                            style={{
                                background:
                                    'radial-gradient(50% 50% at 50% 50%, rgba(217, 217, 217, 0) 0%, #FFFFFF 100%)',
                            }}
                        >
                            <div class="px-6 py-4 bg-appText rounded-[32px] leading-none font-medium tracking-[-0.41px] text-white">
                                Open project
                            </div>
                        </div>
                    </a>
                    {item.gallery.length > 0 && (
                        <div
                            class={`homePortfolio--galleryPagination homePortfolio--galleryPagination_${index} mt-6 lg:mt-8`}
                        />
                    )}
                </div>
            ))}
        </div>
    </div>
</section>
